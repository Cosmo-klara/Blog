---
import PageLayout from '@/layouts/CommonPage.astro'
import { TODO_AUTH_COOKIE_NAME, verifyTodoAuthToken } from '@/utils/todoAuth'

export const prerender = false

const headings = [
  { depth: 2, slug: 'auth', text: 'Auth' },
  { depth: 2, slug: 'todo', text: 'TODO' }
]

const token = Astro.cookies.get(TODO_AUTH_COOKIE_NAME)?.value
const authed = verifyTodoAuthToken(token)
---

<PageLayout title='TODO' {headings}>
  <h2 id='auth'>Auth</h2>

  {authed && (
    <div class='not-prose flex items-center gap-3'>
      <p class='m-0 text-sm text-muted-foreground'>已登录（cookie 记住状态）</p>
      <button class='rounded-md border px-3 py-1.5 text-sm' id='todo-logout-btn' type='button'>
        Logout
      </button>
    </div>
  )}

  <h2 id='todo'>TODO</h2>
  <ul>
    <li>整理实验记录到博客</li>
    <li>补齐部署/监控说明文档</li>
    <li>页面：支持更清晰的任务分组（Inbox / Doing / Done）</li>
  </ul>
  <p class='text-muted-foreground'>提示：当前 TODO 内容写在页面里，你也可以后续改成从 JSON/Markdown 读取。</p>

  {!authed && (
    <div class='todo-lock-overlay' aria-label='TODO authentication overlay'>
      <div class='todo-lock-panel'>
        <p class='m-0 text-sm text-muted-foreground'>权限不足：请输入四位密码后才能查看内容。</p>
        <form class='mt-3 flex items-center gap-3' id='todo-login-form'>
          <input
            class='w-36 rounded-md border bg-background px-3 py-2 text-sm'
            inputmode='numeric'
            autocomplete='one-time-code'
            pattern='\\d{4}'
            maxlength='4'
            minlength='4'
            name='pin'
            placeholder='4-digit PIN'
            required
          />
          <button class='rounded-md border px-3 py-2 text-sm' type='submit'>Login</button>
        </form>
        <p class='m-0 mt-3 text-sm text-muted-foreground' id='todo-login-msg'></p>
      </div>
    </div>
  )}

  {!authed && (
    <style>
      :global(body) {
        overflow: hidden;
      }

      :global(#content-header),
      :global(#content),
      :global(.bottom) {
        filter: blur(64px);
        opacity: 0.015;
        transform: translateZ(0);
        pointer-events: none;
        user-select: none;
        -webkit-user-select: none;
      }
    </style>
  )}
</PageLayout>

<script>
  const loginForm = document.getElementById('todo-login-form') as HTMLFormElement | null
  const loginMsg = document.getElementById('todo-login-msg') as HTMLParagraphElement | null
  const logoutBtn = document.getElementById('todo-logout-btn') as HTMLButtonElement | null

  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!loginMsg) return

    loginMsg.textContent = 'Checking...'
    const form = e.currentTarget
    if (!(form instanceof HTMLFormElement)) return

    const fd = new FormData(form)
    const pin = String(fd.get('pin') || '')

    try {
      const res = await fetch('/api/todo/login', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ pin })
      })
      const data = await res.json().catch(() => ({}))
      if (res.ok && data?.ok) {
        window.location.reload()
        return
      }
      loginMsg.textContent = data?.message || 'Login failed.'
    } catch {
      loginMsg.textContent = 'Network error.'
    }
  })

  logoutBtn?.addEventListener('click', async () => {
    await fetch('/api/todo/logout', { method: 'POST' }).catch(() => {})
    window.location.reload()
  })
</script>

<style>
  .todo-lock-overlay {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: grid;
    place-items: center;
    padding: 1rem;
    background: hsl(var(--background) / 0.68);
  }

  .todo-lock-panel {
    width: min(92vw, 26rem);
    border-radius: 0.75rem;
    border: 1px solid hsl(var(--border) / 1);
    background: hsl(var(--background) / 0.92);
    padding: 1rem;
    box-shadow:
      0 30px 80px hsl(var(--foreground) / 0.18),
      0 1px 0 hsl(var(--foreground) / 0.06) inset;
  }

  :global(.dark) .todo-lock-overlay {
    background: hsl(var(--background) / 0.5);
  }

  :global(.dark) .todo-lock-panel {
    background: hsl(var(--muted) / 0.9);
  }
</style>
