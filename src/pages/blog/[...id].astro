---
import { type CollectionEntry, render } from 'astro:content'

import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import PostLayout from '@/layouts/BlogPost.astro'

export const prerender = true

export async function getStaticPaths() {
  const posts = sortMDByDate(await getBlogCollection())
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post, posts }
  }))
}

type Props = {
  post: CollectionEntry<'blog'>
  posts: CollectionEntry<'blog'>[]
}

const { post, posts } = Astro.props

const blockedPostIds = new Set(['2_week6'])
const isBlocked = blockedPostIds.has(post.id)

let Content
let headings = []
let remarkPluginFrontmatter = {}

if (!isBlocked) {
  ;({ Content, headings, remarkPluginFrontmatter } = await render(post))
}
---

<PostLayout {post} {posts} {headings} {remarkPluginFrontmatter}>
  {
    isBlocked ? (
      <div class='px-4 py-10 text-center sm:px-6 lg:px-8'>
        <h1 class='block text-3xl font-medium'>渲染出错</h1>
        <p class='mt-3 text-muted-foreground'>该文章暂时无法查看。</p>
      </div>
    ) : (
      <Content />
    )
  }
</PostLayout>
