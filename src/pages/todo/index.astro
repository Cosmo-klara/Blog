---
import PageLayout from '@/layouts/CommonPage.astro'
import { TODO_AUTH_COOKIE_NAME, verifyTodoAuthToken } from '@/utils/todoAuth'

export const prerender = false

const token = Astro.cookies.get(TODO_AUTH_COOKIE_NAME)?.value
const authed = verifyTodoAuthToken(token)

const headings = authed
  ? [
      { depth: 2, slug: 'auth', text: 'Auth' },
      { depth: 2, slug: 'todo', text: 'TODO' }
    ]
  : [{ depth: 2, slug: 'auth', text: 'Auth' }]
---

<PageLayout title='TODO Record' {headings}>

  {authed && (
    <div class='not-prose flex items-center gap-3'>
      <button class='rounded-md border px-3 py-1.5 text-sm' id='todo-logout-btn' type='button'>
        Logout
      </button>
    </div>
  )}

  {!authed ? (
    <div class='todo-login-wrap not-prose'>
      <div class='todo-login-card'>
        <p class='m-0 text-sm text-muted-foreground'>权限不足：请输入四位密码后查看内容。</p>
        <form class='mt-3 flex items-center gap-3' id='todo-login-form'>
          <input
            class='w-36 rounded-md border bg-background px-3 py-2 text-sm'
            inputmode='numeric'
            autocomplete='one-time-code'
            pattern='\\d{4}'
            maxlength='4'
            minlength='4'
            name='pin'
            placeholder='4-digit PIN'
            required
          />
          <button class='rounded-md border px-3 py-2 text-sm' type='submit'>Login</button>
        </form>
        <p class='m-0 mt-3 text-sm text-muted-foreground' id='todo-login-msg'></p>
      </div>
    </div>
  ) : (
    <>
      <h2 id='todo'>TODO</h2>
      <ul id='todo-list'></ul>

      <div class='todo-editor not-prose'>
        <p class='m-0 text-sm text-muted-foreground'>每行一条 TODO，点保存后会写入当前浏览器的本地存储。</p>
        <textarea
          id='todo-editor'
          class='mt-3 w-full rounded-md border bg-background px-3 py-2 text-sm'
          rows={10}
          spellcheck='false'
        ></textarea>
        <div class='mt-3 flex items-center gap-3'>
          <button class='rounded-md border px-3 py-2 text-sm' id='todo-save-btn' type='button'>
            Save
          </button>
          <button class='rounded-md border px-3 py-2 text-sm' id='todo-reset-btn' type='button'>
            Reset
          </button>
          <p class='m-0 text-sm text-muted-foreground' id='todo-save-msg'></p>
        </div>
      </div>
    </>
  )}
</PageLayout>

<script>
  const loginForm = document.getElementById('todo-login-form') as HTMLFormElement | null
  const loginMsg = document.getElementById('todo-login-msg') as HTMLParagraphElement | null
  const logoutBtn = document.getElementById('todo-logout-btn') as HTMLButtonElement | null

  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!loginMsg) return

    loginMsg.textContent = 'Checking...'
    const form = e.currentTarget
    if (!(form instanceof HTMLFormElement)) return

    const fd = new FormData(form)
    const pin = String(fd.get('pin') || '')

    try {
      const res = await fetch('/api/todo/login', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ pin })
      })
      const data = await res.json().catch(() => ({}))
      if (res.ok && data?.ok) {
        window.location.reload()
        return
      }
      loginMsg.textContent = data?.message || 'Login failed.'
    } catch {
      loginMsg.textContent = 'Network error.'
    }
  })

  logoutBtn?.addEventListener('click', () => {
    window.location.href = '/api/todo/logout?next=/todo'
  })

  const TODO_LOCAL_STORAGE_KEY = 'todo_content'
  const DEFAULT_TODO = ['整理实验记录到博客', '补齐部署/监控说明文档', '页面：支持更清晰的任务分组（Inbox / Doing / Done）'].join('\n')

  const todoEditor = document.getElementById('todo-editor') as HTMLTextAreaElement | null
  const todoList = document.getElementById('todo-list') as HTMLUListElement | null
  const todoSaveBtn = document.getElementById('todo-save-btn') as HTMLButtonElement | null
  const todoResetBtn = document.getElementById('todo-reset-btn') as HTMLButtonElement | null
  const todoSaveMsg = document.getElementById('todo-save-msg') as HTMLParagraphElement | null

  const normalizeLine = (line: string) => line.replace(/^\s*[-*]\s+/, '').trim()

  const renderTodoList = (raw: string) => {
    if (!todoList) return
    todoList.innerHTML = ''

    const lines = raw
      .split(/\r?\n/)
      .map(normalizeLine)
      .filter(Boolean)

    for (const line of lines) {
      const li = document.createElement('li')
      li.textContent = line
      todoList.appendChild(li)
    }
  }

  const loadTodo = () => {
    if (!todoEditor) return
    const raw = localStorage.getItem(TODO_LOCAL_STORAGE_KEY) ?? DEFAULT_TODO
    todoEditor.value = raw
    renderTodoList(raw)
  }

  const saveTodo = () => {
    if (!todoEditor) return
    const raw = todoEditor.value
    localStorage.setItem(TODO_LOCAL_STORAGE_KEY, raw)
    renderTodoList(raw)
    if (todoSaveMsg) todoSaveMsg.textContent = 'Saved.'
  }

  todoEditor?.addEventListener('input', () => {
    if (!todoEditor) return
    renderTodoList(todoEditor.value)
    if (todoSaveMsg) todoSaveMsg.textContent = ''
  })

  todoSaveBtn?.addEventListener('click', saveTodo)

  todoResetBtn?.addEventListener('click', () => {
    localStorage.removeItem(TODO_LOCAL_STORAGE_KEY)
    loadTodo()
    if (todoSaveMsg) todoSaveMsg.textContent = 'Reset.'
  })

  loadTodo()
</script>

<style>
  .todo-login-wrap {
    display: grid;
    place-items: center;
    padding: 2rem 0;
  }

  .todo-login-card {
    width: min(92vw, 26rem);
    border-radius: 0.75rem;
    border: 1px solid hsl(var(--border) / 1);
    background: hsl(var(--background) / 1);
    padding: 1rem;
    box-shadow:
      0 20px 60px hsl(var(--foreground) / 0.12),
      0 1px 0 hsl(var(--foreground) / 0.06) inset;
  }

  #todo-list {
    margin-top: 1rem;
  }

  .todo-editor {
    margin-top: 1.25rem;
  }

  :global(.dark) .todo-login-card {
    background: hsl(var(--muted) / 0.7);
  }
</style>
